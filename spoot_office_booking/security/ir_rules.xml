<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">

    <!-- ──────────────────────────────────────────────────────────────
         RESERVAS: usuarios regulares solo ven sus propias reservas.
         Managers (base.group_system) no tienen regla → ven todo.
         (Odoo hace OR entre grupos, así que group_system sin regla = sin restricción)
         ────────────────────────────────────────────────────────────── -->
    <record id="rule_booking_own_user" model="ir.rule">
      <field name="name">Reservas: solo las propias (usuarios)</field>
      <field name="model_id" ref="model_spoot_office_booking"/>
      <field name="groups" eval="[(4, ref('base.group_user'))]"/>
      <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
      <field name="perm_read"  eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ──────────────────────────────────────────────────────────────
         SUSCRIPCIONES: usuarios regulares solo ven la suya.
         Managers ven todas.
         ────────────────────────────────────────────────────────────── -->
    <record id="rule_subscription_own_user" model="ir.rule">
      <field name="name">Suscripciones: solo las propias (usuarios)</field>
      <field name="model_id" ref="model_spoot_coworking_subscription"/>
      <field name="groups" eval="[(4, ref('base.group_user'))]"/>
      <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
      <field name="perm_read"  eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

  </data>
</odoo>
