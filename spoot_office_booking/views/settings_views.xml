<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_spoot_office_settings_form" model="ir.ui.view">
        <field name="name">spoot.office.settings.form</field>
        <field name="model">spoot.office.settings</field>
        <field name="arch" type="xml">
            <form string="Configuración">
                <sheet>

                    <div class="o_setting_container">

                        <!-- ── SECCIÓN: Notificaciones ─────────────────── -->
                        <div class="o_settings_header">
                            <h2>Notificaciones</h2>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_left_pane">
                                <i class="fa fa-envelope-o fa-2x text-muted" title="Correo"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="admin_email" class="o_field_widget fw-bold">
                                    Correo del administrador
                                </label>
                                <div class="text-muted" style="font-size:13px;margin-bottom:6px;">
                                    Recibe avisos de nuevas reservas, cancelaciones y pagos.
                                    Si se deja vacío se usa el correo de la empresa.
                                </div>
                                <field name="admin_email"
                                       placeholder="admin@miempresa.com"
                                       style="max-width:340px;"/>
                            </div>
                        </div>

                        <div class="o_settings_header mt-4">
                            <h2>Plantillas de correo</h2>
                            <p class="text-muted" style="font-size:13px;font-weight:normal;">
                                Haz clic en <strong>Editar</strong> para personalizar el asunto y el cuerpo de cada correo.
                                Los cambios se aplican de inmediato.
                            </p>
                        </div>

                        <!-- Tabla de plantillas -->
                        <div class="o_setting_box" style="display:block;">
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr style="border-bottom:2px solid #e5e7eb;">
                                        <th style="text-align:left;padding:8px 12px;font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;">Evento</th>
                                        <th style="text-align:left;padding:8px 12px;font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;">Destinatario</th>
                                        <th style="width:100px;"/>
                                    </tr>
                                </thead>
                                <tbody>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Nueva reserva (pago pendiente Bold)</div>
                                            <div class="text-muted" style="font-size:12px;">Se envía cuando el cliente crea una reserva y paga por Bold.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#dbeafe;color:#1d4ed8;">Cliente</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_pending"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Reserva confirmada con plan</div>
                                            <div class="text-muted" style="font-size:12px;">Se envía cuando la reserva queda confirmada usando días del plan.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#dbeafe;color:#1d4ed8;">Cliente</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_confirmed_plan"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Reserva confirmada con pago Bold</div>
                                            <div class="text-muted" style="font-size:12px;">Se envía cuando Bold confirma el pago y la reserva queda activa.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#dbeafe;color:#1d4ed8;">Cliente</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_confirmed_bold"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Recordatorio de reserva (día anterior)</div>
                                            <div class="text-muted" style="font-size:12px;">Cron diario — recuerda al cliente su reserva del día siguiente.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#dbeafe;color:#1d4ed8;">Cliente</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_reminder"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Reserva cancelada</div>
                                            <div class="text-muted" style="font-size:12px;">Se envía al cliente cuando su reserva es cancelada (por él o por el admin).</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#dbeafe;color:#1d4ed8;">Cliente</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_cancelled_user"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Nueva reserva recibida</div>
                                            <div class="text-muted" style="font-size:12px;">Aviso interno cuando se crea una nueva reserva.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;">Admin</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_new_admin"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td style="padding:12px 12px;">
                                            <div class="fw-semibold">Reserva cancelada (notificación interna)</div>
                                            <div class="text-muted" style="font-size:12px;">Aviso interno cuando se cancela una reserva.</div>
                                        </td>
                                        <td style="padding:12px 12px;">
                                            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;">Admin</span>
                                        </td>
                                        <td style="padding:12px 12px;text-align:right;">
                                            <button name="action_edit_tpl_booking_cancelled_admin"
                                                    type="object"
                                                    string="Editar"
                                                    class="btn btn-sm btn-outline-primary"/>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>

                    </div>

                </sheet>

                <footer>
                    <button name="action_save"
                            type="object"
                            string="Guardar"
                            class="btn-primary"/>
                    <button special="cancel"
                            string="Cerrar"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>


    <record id="action_spoot_office_settings" model="ir.actions.act_window">
        <field name="name">Configuración</field>
        <field name="res_model">spoot.office.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="view_id" ref="view_spoot_office_settings_form"/>
    </record>

</odoo>
