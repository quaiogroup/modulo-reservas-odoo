<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="spoot_office_booking.SpootAvailabilityDashboard">
<div class="sd-root">

  <!-- ══ HEADER ════════════════════════════════════════════════════ -->
  <div class="sd-header">
    <div class="sd-header__left">
      <div class="sd-header__title">Reservas de oficinas</div>
      <div class="sd-header__sub">Panel de administración</div>
    </div>
    <button class="sd-btn sd-btn--primary" t-on-click="createBooking">
      + Nueva reserva
    </button>
  </div>

  <!-- ══ KPI CARDS ══════════════════════════════════════════════════ -->
  <t t-if="state.stats">
    <div class="sd-kpis">

      <!-- Hoy -->
      <div class="sd-kpi sd-kpi--blue">
        <div class="sd-kpi__icon">📅</div>
        <div class="sd-kpi__body">
          <div class="sd-kpi__value"><t t-esc="state.stats.today_confirmed"/></div>
          <div class="sd-kpi__label">Confirmadas hoy</div>
          <div class="sd-kpi__sub"><t t-esc="state.stats.today_total"/> totales hoy</div>
        </div>
      </div>

      <!-- Semana -->
      <div class="sd-kpi sd-kpi--green">
        <div class="sd-kpi__icon">📆</div>
        <div class="sd-kpi__body">
          <div class="sd-kpi__value"><t t-esc="state.stats.week_confirmed"/></div>
          <div class="sd-kpi__label">Confirmadas esta semana</div>
        </div>
      </div>

      <!-- Pendientes -->
      <div class="sd-kpi sd-kpi--amber" t-on-click="openAllPending"
           style="cursor:pointer;" title="Ver todas las pendientes">
        <div class="sd-kpi__icon">⏳</div>
        <div class="sd-kpi__body">
          <div class="sd-kpi__value"><t t-esc="state.stats.pending_count"/></div>
          <div class="sd-kpi__label">Pendientes de pago</div>
          <div class="sd-kpi__sub">Clic para ver →</div>
        </div>
      </div>

      <!-- Ingresos del mes -->
      <div class="sd-kpi sd-kpi--indigo">
        <div class="sd-kpi__icon">💰</div>
        <div class="sd-kpi__body">
          <div class="sd-kpi__value sd-kpi__value--sm">
            <t t-esc="fmtMoney(state.stats.month_revenue, state.stats.currency)"/>
          </div>
          <div class="sd-kpi__label">Ingresos Bold este mes</div>
          <div class="sd-kpi__sub"><t t-esc="state.stats.month_total"/> reservas en el mes</div>
        </div>
      </div>

    </div>
  </t>

  <!-- ══ CUERPO: 2 columnas (calendario | upcoming) ══════════════════ -->
  <div class="sd-body">

    <!-- ── COLUMNA PRINCIPAL: calendario ────────────────────────── -->
    <div class="sd-col-main">

      <!-- Barra de controles -->
      <div class="sd-controls">
        <div class="sd-controls__nav">
          <button class="sd-btn sd-btn--ghost" t-on-click="() => this.shift(-1)">‹</button>
          <button class="sd-btn sd-btn--today" t-on-click="goToday">Hoy</button>
          <button class="sd-btn sd-btn--ghost" t-on-click="() => this.shift(1)">›</button>
        </div>

        <div class="sd-period-label">
          <t t-if="state.mode === 'month'">
            <t t-esc="state.monthLabel"/>
          </t>
          <t t-else="">
            <t t-esc="state.dateStart"/> — <t t-esc="state.dateEnd"/>
          </t>
        </div>

        <div class="sd-controls__modes">
          <button class="sd-mode-btn" t-att-class="state.mode==='day'?'is-active':''"
                  t-on-click="() => this.setMode('day')">Día</button>
          <button class="sd-mode-btn" t-att-class="state.mode==='week'?'is-active':''"
                  t-on-click="() => this.setMode('week')">Semana</button>
          <button class="sd-mode-btn" t-att-class="state.mode==='month'?'is-active':''"
                  t-on-click="() => this.setMode('month')">Mes</button>
        </div>
      </div>

      <!-- Leyenda -->
      <div class="sd-legend">
        <span class="sd-legend-item">
          <span class="sd-dot sd-seg--free"></span> Disponible
        </span>
        <span class="sd-legend-item">
          <span class="sd-dot sd-seg--pending"></span> Pendiente pago
        </span>
        <span class="sd-legend-item">
          <span class="sd-dot sd-seg--busy"></span> Ocupado
        </span>
        <span class="sd-legend-sep"/>
        <span class="sd-legend-hint">
          Clic verde = crear · Clic rojo/amarillo = ver reserva
        </span>
      </div>

      <!-- Cargando -->
      <t t-if="state.loading">
        <div class="sd-card sd-loading">
          <div class="sd-loading__bar"/>
          <div class="sd-loading__bar sd-loading__bar--short"/>
          <div class="sd-loading__text">Cargando…</div>
        </div>
      </t>

      <!-- Matriz -->
      <t t-else="">
        <div class="sd-card sd-matrix-card">

          <!-- ── MODO MES ── -->
          <t t-if="state.mode === 'month'">
            <div class="sd-month">
              <div class="sd-month__head">
                <div class="sd-month__corner">Oficina</div>
                <div class="sd-month__dow">L</div>
                <div class="sd-month__dow">M</div>
                <div class="sd-month__dow">X</div>
                <div class="sd-month__dow">J</div>
                <div class="sd-month__dow">V</div>
                <div class="sd-month__dow">S</div>
                <div class="sd-month__dow">D</div>
              </div>

              <t t-foreach="state.matrix.rows" t-as="row" t-key="row.office_id">
                <div class="sd-month__row">
                  <div class="sd-month__office"><t t-esc="row.office_name"/></div>
                  <div class="sd-month__scroller">
                    <div class="sd-month__grid">
                      <t t-foreach="state.monthWeeks" t-as="w" t-key="w[0].date">
                        <t t-foreach="w" t-as="d" t-key="d.date">
                          <t t-set="cell" t-value="(row.days_by_date||{})[d.date]"/>
                          <div class="sd-month__cell"
                               t-att-class="(!d.isInMonth ? 'is-out ' : '') + (isToday(d.date) ? 'is-today' : '')">
                            <div class="sd-month__num"><t t-esc="d.day"/></div>
                            <t t-if="cell">
                              <div class="sd-pill sd-pill--sm">
                                <button type="button"
                                  t-att-class="'sd-pill__seg sd-pill__seg--l ' + segClass(cell.segments.morning.status)"
                                  t-on-click="() => this.onSegmentClick(row.office_id, d.date, 'morning', cell.segments.morning)"
                                  title="Mañana"/>
                                <button type="button"
                                  t-att-class="'sd-pill__seg sd-pill__seg--r ' + segClass(cell.segments.afternoon.status)"
                                  t-on-click="() => this.onSegmentClick(row.office_id, d.date, 'afternoon', cell.segments.afternoon)"
                                  title="Tarde"/>
                              </div>
                            </t>
                          </div>
                        </t>
                      </t>
                    </div>
                  </div>
                </div>
              </t>
            </div>
          </t>

          <!-- ── MODO DÍA / SEMANA ── -->
          <t t-else="">
            <div class="sd-table-wrap">
              <table class="sd-table">
                <thead>
                  <tr>
                    <th class="sd-table__office-col">Oficina</th>
                    <t t-foreach="state.matrix.days" t-as="d" t-key="d.date">
                      <th t-att-class="'sd-day-head ' + (isToday(d.date) ? 'is-today' : '')">
                        <div class="sd-day-head__dow"><t t-esc="d.dow"/></div>
                        <div class="sd-day-head__num"><t t-esc="d.day"/></div>
                      </th>
                    </t>
                  </tr>
                </thead>
                <tbody>
                  <t t-foreach="state.matrix.rows" t-as="row" t-key="row.office_id">
                    <tr>
                      <td class="sd-office-cell">
                        <div class="sd-office-cell__name"><t t-esc="row.office_name"/></div>
                      </td>
                      <t t-foreach="row.days" t-as="cell" t-key="cell.date">
                        <td t-att-class="'sd-cell ' + (isToday(cell.date) ? 'is-today' : '')">
                          <div class="sd-pill">
                            <button type="button"
                              t-att-class="'sd-pill__seg sd-pill__seg--l ' + segClass(cell.segments.morning.status)"
                              t-on-click="() => this.onSegmentClick(row.office_id, cell.date, 'morning', cell.segments.morning)"
                              title="Mañana (8–12)"/>
                            <button type="button"
                              t-att-class="'sd-pill__seg sd-pill__seg--r ' + segClass(cell.segments.afternoon.status)"
                              t-on-click="() => this.onSegmentClick(row.office_id, cell.date, 'afternoon', cell.segments.afternoon)"
                              title="Tarde (14–18)"/>
                          </div>
                        </td>
                      </t>
                    </tr>
                  </t>
                </tbody>
              </table>
            </div>
          </t>

        </div>
      </t>
    </div>

    <!-- ── COLUMNA LATERAL: próximas reservas ─────────────────── -->
    <div class="sd-col-side">
      <div class="sd-card sd-upcoming-card">
        <div class="sd-upcoming__header">
          <span class="sd-upcoming__title">Próximas reservas</span>
        </div>

        <t t-if="!state.stats">
          <div class="sd-upcoming__empty">Cargando…</div>
        </t>
        <t t-elif="state.stats.upcoming.length === 0">
          <div class="sd-upcoming__empty">No hay reservas próximas</div>
        </t>
        <t t-else="">
          <div class="sd-upcoming__list">
            <t t-foreach="state.stats.upcoming" t-as="bk" t-key="bk.id">
              <div class="sd-upcoming__item" t-on-click="() => this.openBooking(bk.id)">
                <div class="sd-upcoming__date-col">
                  <div class="sd-upcoming__day">
                    <t t-esc="bk.date.split('-')[2]"/>
                  </div>
                  <div class="sd-upcoming__mon">
                    <t t-esc="fmtDate(bk.date).split(' ')[2] || ''"/>
                  </div>
                </div>
                <div class="sd-upcoming__info">
                  <div class="sd-upcoming__office"><t t-esc="bk.office"/></div>
                  <div class="sd-upcoming__partner"><t t-esc="bk.partner"/></div>
                  <div class="sd-upcoming__slot"><t t-esc="bk.slot"/></div>
                </div>
                <div class="sd-upcoming__badges">
                  <span t-att-class="'sd-badge ' + stateClass(bk.state)">
                    <t t-esc="stateLabel(bk.state)"/>
                  </span>
                  <span t-att-class="'sd-badge ' + payClass(bk.payment_mode)">
                    <t t-esc="payLabel(bk.payment_mode)"/>
                  </span>
                </div>
              </div>
            </t>
          </div>
        </t>
      </div>
    </div>

  </div><!-- /sd-body -->

</div><!-- /sd-root -->
</t>

</templates>
