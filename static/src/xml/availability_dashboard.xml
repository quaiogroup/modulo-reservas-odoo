<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

  <t t-name="spoot_office_booking.SpootAvailabilityDashboard">
    <div class="o_spoot_availability_dashboard">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h2 class="mb-0">Disponibilidad por oficina</h2>
          <small class="text-muted">
            <t t-esc="state.dateStart"/> → <t t-esc="state.dateEnd"/>
          </small>
        </div>

<div class="d-flex gap-2">
  <button class="btn btn-outline-secondary spoot-btn-round" t-on-click="() => shift(-7)">‹</button>
  <button class="btn btn-outline-secondary spoot-btn-round" t-on-click="() => shift(7)">›</button>

  <button class="btn btn-outline-primary spoot-btn-round" t-on-click="() => setMode('day')">Día</button>
  <button class="btn btn-outline-primary spoot-btn-round" t-on-click="() => setMode('week')">Semana</button>
  <button class="btn btn-outline-primary spoot-btn-round" t-on-click="() => setMode('month')">Mes</button>
</div>



      <t t-if="state.loading">
        <div class="alert alert-info">Cargando disponibilidad…</div>
      </t>

      <t t-else="">
        <div class="table-responsive">
          <table class="table table-sm align-middle spoot-availability-table">
            <thead>
              <tr>
                <th style="min-width: 220px;">Oficina</th>
<t t-foreach="state.data.days" t-as="d" t-key="d.date">
                  <th class="text-center" style="min-width: 70px;">
<t t-esc="d.label or d.date"/>
                  </th>
                </t>
              </tr>
            </thead>

            <tbody>
<t t-foreach="state.data.rows" t-as="row" t-key="row.office_id">
                <tr>
                  <td class="fw-semibold">
                    <t t-esc="row.office_name"/>
                  </td>

<t t-foreach="row.days" t-as="cell" t-key="cell.date">
                    <td class="text-center">
                      <!-- Píldora doble: morning + afternoon -->
                      <div class="spoot-pill">
                        <div
                          class="spoot-pill-seg spoot-pill-left"
                          t-att-class="segClass(cell.segments.morning.status)"
                          t-on-click="() => onSegmentClick(row.office_id, cell.date, 'morning', cell.segments.morning)"
                          t-att-title="cell.segments.morning.status"
                        />
                        <div
                          class="spoot-pill-seg spoot-pill-right"
                          t-att-class="segClass(cell.segments.afternoon.status)"
                          t-on-click="() => onSegmentClick(row.office_id, cell.date, 'afternoon', cell.segments.afternoon)"
                          t-att-title="cell.segments.afternoon.status"
                        />
                      </div>
                    </td>
                  </t>
                </tr>
              </t>
            </tbody>
          </table>
        </div>

        <div class="d-flex gap-3 mt-3 small text-muted">
          <span><span class="spoot-legend spoot-pill-free"/> Disponible</span>
          <span><span class="spoot-legend spoot-pill-pending"/> Pendiente pago</span>
          <span><span class="spoot-legend spoot-pill-busy"/> Ocupado</span>
          <span class="ms-auto">Click en verde = crear reserva. Click en rojo/amarillo = ver reserva.</span>
        </div>
      </t>
    </div>
    </div>
  </t>

</templates>
