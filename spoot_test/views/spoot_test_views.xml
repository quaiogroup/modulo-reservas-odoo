<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="view_spoot_test_item_list" model="ir.ui.view">
    <field name="name">spoot.test.item.list</field>
    <field name="model">spoot.test.item</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="notes"/>
      </list>
    </field>
  </record>

  <record id="view_spoot_test_item_form" model="ir.ui.view">
    <field name="name">spoot.test.item.form</field>
    <field name="model">spoot.test.item</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="notes"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_spoot_test_item" model="ir.actions.act_window">
    <field name="name">Spoot Test</field>
    <field name="res_model">spoot.test.item</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_spoot_test_root"
            name="Spoot Test"
            sequence="99"/>

  <menuitem id="menu_spoot_test_items"
            name="Items"
            parent="menu_spoot_test_root"
            action="action_spoot_test_item"
            sequence="10"/>

</odoo>
