<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_spoot_booking_quick_create_wizard_form" model="ir.ui.view">
    <field name="name">spoot.booking.quick.create.wizard.form</field>
    <field name="model">spoot.booking.quick.create.wizard</field>
    <field name="arch" type="xml">
      <form string="Crear reserva rápida">
        <sheet>
          <group>
            <field name="office_id"/>
            <field name="partner_id"/>
          </group>
          <group>
            <field name="date"/>
            <field name="slot_type"/>
          </group>
          <group>
            <field name="need_payment"/>
          </group>
        </sheet>
        <footer>
          <button string="Crear reserva" type="object" name="action_create_booking" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
