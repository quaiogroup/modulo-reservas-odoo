<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Cargar librería Bold en el <head> -->
  <template id="bold_assets" inherit_id="website.layout" name="Bold Assets">
    <xpath expr="//head" position="inside">
      <script type="text/javascript" src="https://checkout.bold.co/library/boldPaymentButton.js"></script>
      <script data-bold-button data-api-key="c31SrZRajMDbFsjMEllgsGN4XYEI6ty7qq5iKbOnfOA"></script>
    </xpath>
  </template>

  <!-- Página de pago (monto fijo): usa SOLO este botón -->
  <template id="bold_pay_page" name="Bold Pay Page">
    <t t-call="website.layout">
      <div class="container py-5">
        <h2 class="mb-3">Pagar reserva</h2>

        <p class="text-muted">
          Reserva: <strong t-esc="booking.name"/> —
          Total: <strong t-esc="bold_amount"/> <t t-esc="bold_currency"/>
        </p>

        <form>
          <script
            data-bold-button="dark-L"
            t-att-data-api-key="bold_api_key"
            t-att-data-order-id="bold_order_id"
            t-att-data-amount="str(bold_amount)"
            t-att-data-currency="bold_currency"
            t-att-data-integrity-signature="bold_integrity"
            t-att-data-redirection-url="bold_redirection_url"
            t-att-data-description="bold_description"
            t-att-data-render-mode="bold_render_mode"
          ></script>
        </form>

        <noscript>
          <p>Activa JavaScript para poder pagar con Bold.</p>
        </noscript>
      </div>
    </t>
  </template>

  <!-- Retorno -->
  <template id="bold_return_page" name="Bold Return Page">
    <t t-call="website.layout">
      <div class="container py-5">
        <h2 class="mb-3">Resultado del pago</h2>

        <p><strong>Referencia:</strong> <t t-esc="order_id"/></p>
        <p><strong>Estado:</strong> <t t-esc="tx_status"/></p>

        <t t-if="booking and getattr(booking, 'payment_state', '') == 'paid'">
          <div class="alert alert-success">Pago aprobado. Reserva confirmada.</div>
        </t>
        <t t-elif="booking and getattr(booking, 'payment_state', '') == 'rejected'">
          <div class="alert alert-danger">Pago rechazado. Puedes intentarlo de nuevo.</div>
        </t>
        <t t-else="">
          <div class="alert alert-warning">Pago en proceso/verificación.</div>
        </t>

        <t t-if="booking">
          <a class="btn btn-primary" t-att-href="'/my/office-bookings/%s' % booking.id">Volver a mi reserva</a>
        </t>
        <t t-else="">
          <a class="btn btn-primary" href="/my">Volver</a>
        </t>
      </div>
    </t>
  </template>

  <!-- Error -->
  <template id="bold_error" name="Bold Error">
    <t t-call="website.layout">
      <div class="container py-5">
        <h2 class="mb-3">No se pudo iniciar el pago</h2>
        <div class="alert alert-danger">
          <t t-esc="error"/>
        </div>
        <t t-if="booking">
          <a class="btn btn-secondary" t-att-href="'/my/office-bookings/%s' % booking.id">Volver</a>
        </t>
      </div>
    </t>
  </template>

</odoo>