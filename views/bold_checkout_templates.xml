<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="bold_pay_page" name="Bold Pay Page">
    <t t-call="website.layout">
      <div class="container py-5">
        <h2 class="mb-3">Redirigiendo a Bold…</h2>
        <p class="text-muted">
          Reserva: <strong t-esc="booking.name"/> —
          Total: <strong t-esc="amount"/> <t t-esc="currency"/>
        </p>

        <!-- Form POST a Bold -->
        <form t-att-action="checkout_url" method="post" id="bold_checkout_form">
          <!-- Campos típicos del checkout embebido -->
          <input type="hidden" name="key" t-att-value="identity_key"/>
          <input type="hidden" name="order_id" t-att-value="order_id"/>
          <input type="hidden" name="amount" t-att-value="amount"/>
          <input type="hidden" name="currency" t-att-value="currency"/>
          <input type="hidden" name="description" t-att-value="payload.get('description')"/>
          <input type="hidden" name="signature" t-att-value="signature"/>

          <!-- URLs -->
          <input type="hidden" name="response_url" t-att-value="payload.get('response_url')"/>
          <input type="hidden" name="webhook_url" t-att-value="payload.get('webhook_url')"/>

          <!-- Si Bold ignora algunos, no pasa nada -->
        </form>

        <script type="text/javascript">
          (function () {
            var f = document.getElementById("bold_checkout_form");
            if (f) { f.submit(); }
          })();
        </script>

        <noscript>
          <p>Activa JavaScript o haz click:</p>
          <button type="submit" form="bold_checkout_form" class="btn btn-primary">Ir a pagar</button>
        </noscript>
      </div>
    </t>
  </template>
</odoo>