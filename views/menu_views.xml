<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ACCIÓN CLIENTE (DASHBOARD OWL) -->
    <record id="action_spoot_availability_dashboard" model="ir.actions.client">
        <field name="name">Disponibilidad</field>
        <field name="tag">spoot_office_booking.availability_dashboard</field>
    </record>

    <!-- ACCIÓN OFICINAS -->
    <record id="action_spoot_office" model="ir.actions.act_window">
        <field name="name">Oficinas</field>
        <field name="res_model">spoot.office</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ACCIÓN RESERVAS -->
    <record id="action_spoot_office_booking" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">spoot.office.booking</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- MENÚ RAÍZ (APP) -->
    <menuitem id="menu_spoot_office_root"
              name="Reservas de oficinas"
              sequence="10"/>

    <!-- SUBMENÚ OFICINAS -->
    <menuitem id="menu_spoot_office"
              name="Oficinas"
              parent="menu_spoot_office_root"
              action="action_spoot_office"
              sequence="10"/>

    <!-- SUBMENÚ RESERVAS -->
    <menuitem id="menu_spoot_office_booking"
              name="Reservas"
              parent="menu_spoot_office_root"
              action="action_spoot_office_booking"
              sequence="20"/>

    <!-- SUBMENÚ DISPONIBILIDAD (DASHBOARD) -->
    <menuitem id="menu_spoot_office_availability_dashboard"
              name="Disponibilidad"
              parent="menu_spoot_office_root"
              action="action_spoot_availability_dashboard"
              sequence="30"/>

</odoo>
