<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Acción: Dashboard de disponibilidad ─────────────────────── -->
    <record id="action_spoot_availability_dashboard" model="ir.actions.client">
        <field name="name">Disponibilidad</field>
        <field name="tag">spoot_office_booking.availability_dashboard</field>
    </record>

    <!-- ── Acción: Oficinas ─────────────────────────────────────────── -->
    <record id="action_spoot_office" model="ir.actions.act_window">
        <field name="name">Oficinas</field>
        <field name="res_model">spoot.office</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Acción: Reservas ─────────────────────────────────────────── -->
    <record id="action_spoot_office_booking" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">spoot.office.booking</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_spoot_office_booking_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aún no hay reservas registradas.
            </p>
            <p>
                Las reservas creadas desde el portal o el backend aparecerán aquí.
            </p>
        </field>
    </record>

    <!-- ── Acción: Suscripciones ────────────────────────────────────── -->
    <record id="action_spoot_coworking_subscription" model="ir.actions.act_window">
        <field name="name">Suscripciones</field>
        <field name="res_model">spoot.coworking.subscription</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_coworking_subscription_list"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         MENÚ RAÍZ
         ══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_spoot_office_root"
              name="Reservas de oficinas"
              sequence="10"/>

    <!-- Oficinas -->
    <menuitem id="menu_spoot_office"
              name="Oficinas"
              parent="menu_spoot_office_root"
              action="action_spoot_office"
              sequence="10"/>

    <!-- Servicios -->
    <menuitem id="menu_spoot_office_service"
              name="Servicios"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_spoot_office_service"
              sequence="12"/>

    <!-- Clientes -->
    <menuitem id="menu_spoot_clients"
              name="Clientes"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_spoot_clients"
              sequence="11"/>

    <!-- Planes -->
    <menuitem id="menu_spoot_coworking_plan"
              name="Planes"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_coworking_plan"
              sequence="15"/>

    <!-- Reservas -->
    <menuitem id="menu_spoot_office_booking"
              name="Reservas"
              parent="menu_spoot_office_root"
              action="action_spoot_office_booking"
              sequence="20"/>

    <!-- Suscripciones -->
    <menuitem id="menu_spoot_coworking_subscription"
              name="Suscripciones"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_spoot_coworking_subscription"
              sequence="30"/>

    <!-- Bloqueos de fechas -->
    <menuitem id="menu_spoot_office_block"
              name="Bloqueos de fechas"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_spoot_office_block"
              sequence="35"/>

    <!-- Disponibilidad (dashboard OWL) -->
    <menuitem id="menu_spoot_office_availability_dashboard"
              name="Disponibilidad"
              parent="menu_spoot_office_root"
              action="action_spoot_availability_dashboard"
              sequence="40"/>

    <!-- Configuración -->
    <menuitem id="menu_spoot_settings"
              name="Configuración"
              parent="menu_spoot_office_root"
              action="spoot_office_booking.action_spoot_office_settings"
              sequence="99"/>

    <!-- Analíticas -->
    <record id="action_spoot_analytics_dashboard" model="ir.actions.client">
        <field name="name">Analíticas</field>
        <field name="tag">spoot_office_booking.analytics_dashboard</field>
    </record>

    <menuitem id="menu_spoot_analytics"
              name="Analíticas"
              parent="menu_spoot_office_root"
              action="action_spoot_analytics_dashboard"
              sequence="50"/>

</odoo>
