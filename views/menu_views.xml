<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ACCIONES (primero) -->
    <record id="action_spoot_office" model="ir.actions.act_window">
        <field name="name">Oficinas</field>
        <field name="res_model">spoot.office</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_spoot_office_booking" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">spoot.office.booking</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- MENÚ RAÍZ -->
    <menuitem id="menu_spoot_office_root"
              name="Reservas de oficinas"
              sequence="10"
              parent="base.menu_custom"/>

    <!-- SUBMENÚ OFICINAS -->
    <menuitem id="menu_spoot_office"
              name="Oficinas"
              parent="menu_spoot_office_root"
              action="action_spoot_office"/>

    <!-- SUBMENÚ RESERVAS -->
    <menuitem id="menu_spoot_office_booking"
              name="Reservas"
              parent="menu_spoot_office_root"
              action="action_spoot_office_booking"/>

</odoo>
