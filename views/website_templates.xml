<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- LISTADO DE OFICINAS -->
  <template id="website_office_list" name="Listado de oficinas">
    <t t-call="website.layout">
      <div class="container py-5">

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
          <div>
            <h1 class="mb-1">Oficinas disponibles</h1>
            <p class="text-muted mb-0">Elige una oficina y reserva en segundos.</p>
          </div>
        </div>

        <div class="row g-4">
          <t t-foreach="offices" t-as="office">
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card h-100 shadow-sm border-0 overflow-hidden">

                <!-- Imagen -->
                <t t-if="office.image_1920">
                  <img t-att-src="'/web/image/spoot.office/%s/image_1920' % office.id"
                       class="card-img-top"
                       style="height: 210px; object-fit: cover;"
                       alt="Office image"/>
                </t>
                <t t-else="">
                  <div class="d-flex align-items-center justify-content-center bg-light"
                       style="height: 210px;">
                    <span class="text-muted">Sin imagen</span>
                  </div>
                </t>

                <div class="card-body d-flex flex-column">
                  <h5 class="card-title mb-1">
                    <t t-esc="office.name"/>
                  </h5>

                  <p class="text-muted mb-3">
                    <t t-esc="office.short_description or office.location or ''"/>
                  </p>

                  <div class="mt-auto d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                      <t t-if="office.capacity">
                        Capacidad: <t t-esc="office.capacity"/>
                      </t>
                    </small>

                    <a t-att-href="'/offices/%s' % office.id"
                       class="btn btn-primary rounded-pill px-3">
                      Ver y reservar
                    </a>
                  </div>
                </div>

              </div>
            </div>
          </t>
        </div>

      </div>
    </t>
  </template>


  <!-- DETALLE OFICINA + FORMULARIO -->
  <template id="website_office_detail" name="Detalle oficina">
    <t t-call="website.layout">
      <div class="container py-5">

        <!-- Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <a href="/offices" class="btn btn-outline-secondary rounded-pill px-3">
            &lt; Volver
          </a>

          <a href="/my/office-bookings" class="btn btn-outline-primary rounded-pill px-3">
            Ver mis reservas
          </a>
        </div>

        <div class="row g-4">

          <!-- COLUMNA IZQUIERDA: fotos + info -->
          <div class="col-12 col-lg-7">

            <div class="card shadow-sm border-0 overflow-hidden">
              <!-- Imagen principal -->
              <t t-if="office.image_1920">
                <img t-att-src="'/web/image/spoot.office/%s/image_1920' % office.id"
                     class="w-100"
                     style="height: 360px; object-fit: cover;"
                     alt="Office image"/>
              </t>
              <t t-else="">
                <div class="d-flex align-items-center justify-content-center bg-light"
                     style="height: 360px;">
                  <span class="text-muted">Sin imagen principal</span>
                </div>
              </t>

              <!-- Galería (si existe image_ids) -->
              <div class="card-body">
                <t t-if="'image_ids' in office._fields and office.image_ids">
                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <t t-foreach="office.image_ids" t-as="img">
                      <a t-att-href="'/web/image/spoot.office.image/%s/image_1920' % img.id"
                         target="_blank"
                         class="text-decoration-none">
                        <img t-att-src="'/web/image/spoot.office.image/%s/image_1920' % img.id"
                             class="rounded-3 border"
                             style="width: 96px; height: 72px; object-fit: cover;"
                             alt="Gallery image"/>
                      </a>
                    </t>
                  </div>
                </t>

                <h2 class="mb-1">
                  <t t-esc="office.name"/>
                </h2>

                <p class="text-muted mb-3">
                  <t t-esc="office.location or ''"/>
                  <t t-if="office.capacity">
                    · Capacidad <t t-esc="office.capacity"/>
                  </t>
                </p>

                <t t-if="office.description">
                  <div class="mb-3">
                    <t t-raw="office.description.replace('\n','&lt;br/>')"/>
                  </div>
                </t>

                <!-- Precios -->
                <div class="bg-light rounded-4 p-3">
                  <h6 class="mb-2">Precios</h6>

                  <div class="d-flex justify-content-between py-1">
                    <span>Mañana (8–12)</span>
                    <strong>
                      <t t-esc="office.price_morning or 0.0"/>
                      <t t-esc="office.currency_id.symbol or ''"/>
                    </strong>
                  </div>

                  <div class="d-flex justify-content-between py-1">
                    <span>Tarde (14–18)</span>
                    <strong>
                      <t t-esc="office.price_afternoon or 0.0"/>
                      <t t-esc="office.currency_id.symbol or ''"/>
                    </strong>
                  </div>

                  <div class="d-flex justify-content-between py-1">
                    <span>Día completo</span>
                    <strong>
                      <t t-esc="office.price_full_day or 0.0"/>
                      <t t-esc="office.currency_id.symbol or ''"/>
                    </strong>
                  </div>
                </div>

              </div>
            </div>

          </div>


          <!-- COLUMNA DERECHA: reserva + agenda -->
          <div class="col-12 col-lg-5">

            <!-- Agenda / ocupación (placeholder visual) -->
             <t t-if="office.service_ids">
  <div class="spootServices">
    <h4 class="spootServices__title">Servicios incluidos</h4>

    <div class="spootServices__grid">
      <t t-foreach="office.service_ids" t-as="srv" t-key="srv.id">
        <div class="spootServices__item">
          <t t-if="srv.icon">
            <i t-att-class="'fa ' + srv.icon + ' spootServices__icon'"/>
          </t>
          <div class="spootServices__text">
            <div class="spootServices__name"><t t-esc="srv.name"/></div>
            <t t-if="srv.description">
              <div class="spootServices__desc"><t t-esc="srv.description"/></div>
            </t>
          </div>
        </div>
      </t>
    </div>
  </div>
</t>



            <!-- Formulario de reserva -->
            <div class="card shadow-sm border-0">
              <div class="card-body">

                <h4 class="mb-3">Reservar esta oficina</h4>

                <t t-if="error">
                  <div class="alert alert-danger rounded-4" role="alert">
                    <t t-esc="error"/>
                  </div>
                </t>
                <div class="js_spoot_office_detail" t-att-data-office-id="office.id">


                <form method="post" class="oe_website_form">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token"/>

                  <div class="mb-3">
                    <label class="form-label">Fecha</label>
                    <input type="date" name="date" class="form-control rounded-4" required="required"/>
                  </div>

                  <div class="mb-3">

<select name="slot_type" id="spoot_slot" class="form-control" required="required">
  <option value="" selected="selected" disabled="disabled">Elige una franja</option>
  <option value="morning">Mañana (8-12)</option>
  <option value="afternoon">Tarde (14-18)</option>
  <option value="full_day">Todo el día</option>
</select>

<div id="spoot_slot_hint" class="form-text"></div>

                  </div>

                  <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">
                    Confirmar reserva
                  </button>

                  <p class="text-muted mt-3 mb-0">
                    Debes iniciar sesión para reservar.
                  </p>
                </form>
                </div>

              </div>
            </div>

          </div>
        </div>

      </div>
    </t>
  </template>


  <!-- GRACIAS -->
  <template id="website_booking_thanks" name="Reserva confirmada">
    <t t-call="website.layout">
      <div class="container py-5">
        <div class="mx-auto text-center" style="max-width: 720px;">
          <h1 class="mb-2">¡Reserva registrada!</h1>
          <p class="text-muted mb-4">
            Registramos tu reserva para <b><t t-esc="booking.office_id.name"/></b>
            el <b><t t-esc="booking.date"/></b>
            (<b><t t-esc="booking.slot_type"/></b>).
          </p>

          <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a href="/my/office-bookings" class="btn btn-primary rounded-pill px-4">
              Ver mis reservas
            </a>
            <a href="/offices" class="btn btn-outline-secondary rounded-pill px-4">
              Reservar otra
            </a>
          </div>

          <p class="text-muted mt-4 mb-0">
            Si configuramos correo/calendario, aquí también confirmaremos el envío automático.
          </p>
        </div>
      </div>
    </t>
  </template>
<template id="coworking_plans_page" name="Planes Coworking">
    <t t-call="website.layout">
        <div class="container py-5">

            <div class="text-center mb-5">
                <h1 class="fw-bold">Planes de Coworking</h1>
                <p class="text-muted">Elige el plan que mejor se adapte a tu ritmo de trabajo.</p>
            </div>

            <div class="row g-4 justify-content-center">
                <t t-foreach="plans" t-as="plan">

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-lg h-100 rounded-4 p-4 text-center">

                            <h4 class="fw-bold mb-2">
                                <t t-esc="plan.name"/>
                            </h4>

                            <div class="display-6 fw-bold text-primary mb-3">
<t t-esc="plan.price"
   t-options='{"widget": "monetary", "display_currency": plan.currency_id}'/>                               <small class="fs-6 text-muted">
                                    <t t-esc="plan.currency_id.symbol"/>
                                </small>
                            </div>

                            <p class="mb-2">
                                <strong><t t-esc="plan.days_included"/></strong> días incluidos
                            </p>

                            <p class="text-muted small mb-3">
                                Vigencia de <t t-esc="plan.validity_days"/> días
                            </p>

                            <t t-if="plan.description">
                                <div class="mb-4 text-muted small">
                                    <t t-esc="plan.description"/>
                                </div>
                            </t>

                            <a t-att-href="'/coworking/checkout/%s' % plan.id"
                               class="btn btn-primary w-100 rounded-pill py-2">
                                Elegir plan
                            </a>

                        </div>
                    </div>

                </t>
            </div>

        </div>
    </t>
</template>
<template id="coworking_checkout_page" name="Checkout Coworking">
  <t t-call="website.layout">
    <!-- Bold checkout library — required for the payment button -->
    <script type="text/javascript"
            src="https://checkout.bold.co/library/boldPaymentButton.js"/>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-6">

          <!-- Back link -->
          <div class="mb-3">
            <a href="/coworking/plans" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
              &#8592; Ver todos los planes
            </a>
          </div>

          <div class="card border-0 shadow-lg rounded-4 p-4">

            <!-- Header -->
            <div class="text-center mb-4">
              <h2 class="fw-bold mb-1">Confirmar tu plan</h2>
              <p class="text-muted mb-0">Estás a un paso de activar tu acceso.</p>
            </div>

            <!-- Plan name + price -->
            <div class="text-center mb-3">
              <h3 class="fw-bold mb-1"><t t-esc="plan.name"/></h3>
              <div class="display-5 fw-bold text-primary">
                <t t-esc="plan.price"
                   t-options='{"widget": "monetary", "display_currency": plan.currency_id}'/>
              </div>
            </div>

            <!-- Plan details -->
            <div class="bg-light rounded-4 p-3 mb-4">
              <div class="d-flex justify-content-between py-1">
                <span class="text-muted">Días incluidos</span>
                <strong><t t-esc="plan.days_included"/></strong>
              </div>
              <div class="d-flex justify-content-between py-1">
                <span class="text-muted">Vigencia</span>
                <strong><t t-esc="plan.validity_days"/> días</strong>
              </div>
              <t t-if="plan.description">
                <hr class="my-2"/>
                <p class="small text-muted mb-0"><t t-esc="plan.description"/></p>
              </t>
            </div>

            <!-- ── BOLD PAYMENT BUTTON ──────────────────────────────── -->
            <t t-if="bold_api_key">
              <script
                data-bold-button="dark-L"
                t-att-data-api-key="bold_api_key"
                t-att-data-order-id="bold_order_id"
                t-att-data-amount="str(bold_amount)"
                t-att-data-currency="bold_currency"
                t-att-data-integrity-signature="bold_integrity"
                t-att-data-redirection-url="bold_redirection_url"
                t-att-data-description="bold_description"
                data-render-mode="embedded"
              />
            </t>

            <!-- Shown when Bold keys are not yet configured in Settings -->
            <t t-else="">
              <div class="alert alert-warning rounded-3 text-center small mb-0">
                El sistema de pago no está configurado todavía.
                Contacta al administrador.
              </div>
            </t>
            <!-- ─────────────────────────────────────────────────────── -->

            <p class="text-center text-muted small mt-3 mb-0">
              Pago seguro &#183; Activación inmediata
            </p>

          </div>
        </div>
      </div>
    </div>
  </t>
</template>
<template id="my_coworking_dashboard" name="Mi Coworking">
  <t t-call="portal.portal_layout">
    <t t-set="title">Mi Coworking</t>

    <div class="container py-5">

      <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-5">
        <div>
          <h2 class="fw-bold mb-1">Mi Coworking</h2>
          <p class="text-muted mb-0">
            Bienvenido, <strong><t t-esc="request.env.user.name"/></strong>
          </p>
        </div>
        <a href="/offices" class="btn btn-primary rounded-pill px-4">
          Reservar espacio
        </a>
      </div>

      <!-- ── PLAN + STATS ROW ────────────────────────────────────── -->
      <div class="row g-4 mb-5">

        <t t-if="subscription">

          <!-- Plan card -->
          <div class="col-12 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
              <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div>
                    <p class="text-uppercase fw-semibold text-muted small mb-1" style="letter-spacing:.06em;">
                      Plan activo
                    </p>
                    <h4 class="fw-bold mb-0">
                      <t t-esc="subscription.plan_id.name"/>
                    </h4>
                  </div>
                  <span class="badge rounded-pill px-3 py-2"
                        style="background:#d1fae5; color:#065f46; font-size:.75rem;">
                    Activo
                  </span>
                </div>

                <hr class="my-3"/>

                <!-- Days breakdown -->
                <div class="row g-2 text-center mb-3">
                  <div class="col-4">
                    <div class="bg-light rounded-3 py-2 px-1">
                      <p class="fw-bold fs-5 mb-0">
                        <t t-esc="subscription.total_days"/>
                      </p>
                      <p class="text-muted small mb-0">Incluidos</p>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="rounded-3 py-2 px-1" style="background:#eff6ff;">
                      <p class="fw-bold fs-5 mb-0 text-primary">
                        <t t-esc="days_used"/>
                      </p>
                      <p class="text-muted small mb-0">Usados</p>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="rounded-3 py-2 px-1" style="background:#f0fdf4;">
                      <p class="fw-bold fs-5 mb-0 text-success">
                        <t t-esc="subscription.remaining_days"/>
                      </p>
                      <p class="text-muted small mb-0">Restantes</p>
                    </div>
                  </div>
                </div>

                <!-- Progress bar -->
                <div class="mb-3">
                  <div class="d-flex justify-content-between small text-muted mb-1">
                    <span>Uso del plan</span>
                    <span><t t-esc="days_pct"/>%</span>
                  </div>
                  <div class="progress rounded-pill" style="height:8px; background:#e5e7eb;">
<div class="progress-bar rounded-pill"
     role="progressbar"
     t-att-style="'width:' + str(days_pct) + '%; background:#3b82f6;'"
     t-att-aria-valuenow="days_pct"
     aria-valuemin="0"
     aria-valuemax="100"/>
                  </div>
                </div>

                <!-- Dates -->
                <div class="d-flex justify-content-between small text-muted pt-1">
                  <span>
                    Inicio:
                    <strong class="text-dark"><t t-esc="subscription.start_date"/></strong>
                  </span>
                  <span>
                    Vence:
                    <strong class="text-dark"><t t-esc="subscription.end_date"/></strong>
                  </span>
                </div>

              </div>
            </div>
          </div>

          <!-- Stats grid -->
          <div class="col-12 col-lg-7">
            <div class="row g-3 h-100">

              <div class="col-6">
                <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
                  <p class="fw-bold fs-3 mb-1 text-dark">
                    <t t-esc="booking_total"/>
                  </p>
                  <p class="small text-muted mb-0">Reservas totales</p>
                </div>
              </div>

              <div class="col-6">
                <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100"
                     style="border-left: 3px solid #10b981 !important;">
                  <p class="fw-bold fs-3 mb-1 text-success">
                    <t t-esc="booking_confirmed"/>
                  </p>
                  <p class="small text-muted mb-0">Confirmadas</p>
                </div>
              </div>

              <div class="col-6">
                <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100"
                     style="border-left: 3px solid #f59e0b !important;">
                  <p class="fw-bold fs-3 mb-1 text-warning">
                    <t t-esc="booking_pending"/>
                  </p>
                  <p class="small text-muted mb-0">Pendientes de pago</p>
                </div>
              </div>

              <div class="col-6">
                <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100"
                     style="border-left: 3px solid #6b7280 !important;">
                  <p class="fw-bold fs-3 mb-1 text-secondary">
                    <t t-esc="booking_cancelled"/>
                  </p>
                  <p class="small text-muted mb-0">Canceladas</p>
                </div>
              </div>

            </div>
          </div>

        </t>

        <!-- No active plan -->
        <t t-else="">
          <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 text-center py-5 px-4">
              <div class="mb-3">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-light"
                      style="width:72px; height:72px; font-size:2rem;">
                  &#127970;
                </span>
              </div>
              <h5 class="fw-bold mb-2">Sin plan activo</h5>
              <p class="text-muted mb-4" style="max-width:420px; margin:0 auto;">
                Activa un plan de coworking para gestionar tus accesos y reservas desde aquí.
              </p>
              <div>
                <a href="/coworking/plans" class="btn btn-primary rounded-pill px-5">
                  Ver planes disponibles
                </a>
              </div>
            </div>
          </div>
        </t>

      </div>

      <!-- ── BOOKINGS SECTION ────────────────────────────────────── -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">Mis reservas recientes</h5>
        <a href="/my/office-bookings"
           class="btn btn-outline-secondary btn-sm rounded-pill px-3">
          Ver todas
        </a>
      </div>

      <t t-if="bookings">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead style="background:#f8fafc;">
                <tr>
                  <th class="ps-4 py-3 text-muted fw-semibold small text-uppercase"
                      style="letter-spacing:.05em;">Oficina</th>
                  <th class="py-3 text-muted fw-semibold small text-uppercase"
                      style="letter-spacing:.05em;">Fecha</th>
                  <th class="py-3 text-muted fw-semibold small text-uppercase"
                      style="letter-spacing:.05em;">Franja</th>
                  <th class="py-3 text-center text-muted fw-semibold small text-uppercase"
                      style="letter-spacing:.05em;">Estado</th>
                  <th class="py-3 text-center text-muted fw-semibold small text-uppercase"
                      style="letter-spacing:.05em;">Pago</th>
                  <th class="pe-4 py-3"/>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="bookings" t-as="b">
                  <tr>
                    <td class="ps-4 fw-semibold">
                      <t t-esc="b.office_id.name"/>
                    </td>
                    <td class="text-muted">
                      <t t-esc="b.date"/>
                    </td>
                    <td>
                      <t t-if="b.slot_type == 'morning'">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#e0f2fe; color:#0369a1;">
                          Mañana
                        </span>
                      </t>
                      <t t-elif="b.slot_type == 'afternoon'">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#fef3c7; color:#92400e;">
                          Tarde
                        </span>
                      </t>
                      <t t-else="">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#f3f4f6; color:#374151;">
                          Dia completo
                        </span>
                      </t>
                    </td>
                    <td class="text-center">
                      <t t-if="b.state == 'confirmed'">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#d1fae5; color:#065f46;">
                          Confirmada
                        </span>
                      </t>
                      <t t-elif="b.state == 'pending_payment'">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#fef3c7; color:#92400e;">
                          Pend. pago
                        </span>
                      </t>
                      <t t-elif="b.state == 'cancelled'">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#f3f4f6; color:#6b7280;">
                          Cancelada
                        </span>
                      </t>
                      <t t-else="">
                        <span class="badge rounded-pill px-3 py-1 bg-light text-muted">
                          <t t-esc="b.state"/>
                        </span>
                      </t>
                    </td>
                    <td class="text-center">
                      <t t-if="b.paid">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#d1fae5; color:#065f46;">
                          Pagado
                        </span>
                      </t>
                      <t t-else="">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#fee2e2; color:#991b1b;">
                          Pendiente
                        </span>
                      </t>
                    </td>
                    <td class="pe-4 text-end">
                      <a t-att-href="'/my/office-bookings/%s' % b.id"
                         class="btn btn-sm btn-outline-primary rounded-pill px-3">
                        Ver
                      </a>
                    </td>
                  </tr>
                </t>
              </tbody>
            </table>
          </div>
        </div>
      </t>

      <!-- Empty bookings state -->
      <t t-else="">
        <div class="card border-0 shadow-sm rounded-4 text-center py-5 px-4">
          <div class="mb-3">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-light"
                  style="width:64px; height:64px; font-size:1.8rem;">
              &#128197;
            </span>
          </div>
          <h6 class="fw-bold mb-2">Sin reservas todavía</h6>
          <p class="text-muted mb-4">
            Tus reservas de espacios aparecerán aquí para que puedas seguirlas.
          </p>
          <div>
            <a href="/offices" class="btn btn-primary rounded-pill px-5">
              Reservar una oficina
            </a>
          </div>
        </div>
      </t>

    </div>
  </t>
</template>
</odoo>
