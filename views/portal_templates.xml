<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LISTA DE RESERVAS DEL PORTAL (MEJORADA) -->
    <template id="portal_my_bookings" name="Mis reservas de oficina">
        <t t-call="portal.portal_layout">
            <t t-set="title">Mis reservas de oficina</t>
            <div class="o_portal_wrap">
                <div class="o_portal_my_doc">

                    <!-- Header con botón para reservar -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="mb-0">Mis reservas de oficina</h2>
                        <a href="/offices" class="btn btn-primary btn-sm">
                            + Reservar una oficina
                        </a>
                    </div>

                    <!-- Si hay reservas -->
                    <t t-if="bookings">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Referencia</th>
                                        <th>Oficina</th>
                                        <th>Fecha</th>
                                        <th>Franja</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center">Pagado</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="bookings" t-as="booking">
                                        <tr>
                                            <!-- Referencia -->
                                            <td>
                                                <a t-att-href="'/my/office-bookings/%s' % booking.id">
                                                    <t t-esc="booking.name or 'Reserva sin referencia'"/>
                                                </a>
                                            </td>

                                            <!-- Oficina -->
                                            <td>
                                                <t t-esc="booking.office_id.name"/>
                                            </td>

                                            <!-- Fecha -->
                                            <td>
                                                <t t-esc="booking.date"/>
                                            </td>

                                            <!-- Franja amigable -->
                                            <td>
                                                <t t-if="booking.slot_type == 'morning'">
                                                    Mañana (8:00 – 12:00)
                                                </t>
                                                <t t-elif="booking.slot_type == 'afternoon'">
                                                    Tarde (14:00 – 18:00)
                                                </t>
                                                <t t-else="">
                                                    Día completo
                                                </t>
                                            </td>

                                            <!-- Estado con badge -->
                                            <td class="text-center">
                                                <t t-if="booking.state == 'confirmed'">
                                                    <span class="badge bg-success">Confirmada</span>
                                                </t>
                                                <t t-elif="booking.state == 'pending_payment'">
                                                    <span class="badge bg-warning text-dark">Pendiente de pago</span>
                                                </t>
                                                <t t-elif="booking.state == 'cancelled'">
                                                    <span class="badge bg-secondary">Cancelada</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge bg-light text-dark">
                                                        <t t-esc="booking.state or 'Borrador'"/>
                                                    </span>
                                                </t>
                                            </td>

                                            <!-- Pagado -->
                                            <td class="text-center">
                                                <t t-if="booking.paid">
                                                    <span class="badge bg-success">Sí</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge bg-danger">No</span>
                                                </t>
                                            </td>

                                            <!-- Acciones -->
                                            <td class="text-end">
                                                <a t-att-href="'/my/office-bookings/%s' % booking.id"
                                                   class="btn btn-sm btn-outline-secondary">
                                                    Ver
                                                </a>

                                                <!-- Mostrar botón de cancelar solo si no está cancelada ni pagada -->
                                                <t t-if="booking.state != 'cancelled' and not booking.paid">
                                                    <a t-att-href="'/my/office-bookings/%s/cancel' % booking.id"
                                                       class="btn btn-sm btn-outline-danger ms-1"
                                                       t-att-data-confirm="'¿Seguro que quieres cancelar esta reserva?'">
                                                        Cancelar
                                                    </a>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>

                    <!-- Si NO hay reservas -->
                    <t t-else="">
                        <div class="alert alert-info mt-3">
                            <h5 class="alert-heading">Todavía no tienes reservas 📅</h5>
                            <p class="mb-2">
                                Cuando reserves una oficina desde la web, aparecerá aquí para que puedas
                                consultarla y gestionarla.
                            </p>
                            <a href="/offices" class="btn btn-primary btn-sm">
                                Reservar mi primera oficina
                            </a>
                        </div>
                    </t>

                </div>
            </div>
        </t>
    </template>
        <!-- DETALLE DE RESERVA EN PORTAL (MEJORADO) -->
    <template id="portal_booking_detail" name="Detalle reserva oficina">
        <t t-call="portal.portal_layout">
            <t t-set="title">Detalle de la reserva</t>
            <div class="o_portal_wrap">
                <div class="o_portal_my_doc">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="mb-0">
                            Reserva
                            <t t-esc="booking.name or ('#%s' % booking.id)"/>
                        </h2>

                        <a href="/my/office-bookings" class="btn btn-link btn-sm">
                            &lt; Volver a mis reservas
                        </a>
                    </div>

                    <div class="card mb-3">
                        <div class="card-body">

                            <!-- Estado -->
                            <p class="mb-3">
                                <strong>Estado:</strong>
                                <t t-if="booking.state == 'confirmed'">
                                    <span class="badge bg-success">Confirmada</span>
                                </t>
                                <t t-elif="booking.state == 'pending_payment'">
                                    <span class="badge bg-warning text-dark">Pendiente de pago</span>
                                </t>
                                <t t-elif="booking.state == 'cancelled'">
                                    <span class="badge bg-secondary">Cancelada</span>
                                </t>
                                <t t-else="">
                                    <span class="badge bg-light text-dark">
                                        <t t-esc="booking.state or 'Borrador'"/>
                                    </span>
                                </t>
                            </p>

                            <!-- Datos principales -->
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Oficina</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="booking.office_id.name"/>
                                </dd>

                                <dt class="col-sm-3">Fecha</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="booking.date"/>
                                </dd>

                                <dt class="col-sm-3">Franja</dt>
                                <dd class="col-sm-9">
                                    <t t-if="booking.slot_type == 'morning'">
                                        Mañana (8:00 – 12:00)
                                    </t>
                                    <t t-elif="booking.slot_type == 'afternoon'">
                                        Tarde (14:00 – 18:00)
                                    </t>
                                    <t t-else="">
                                        Día completo
                                    </t>
                                </dd>

                                <dt class="col-sm-3">Pagado</dt>
                                <dd class="col-sm-9">
                                    <t t-if="booking.paid">Sí</t>
                                    <t t-else="">No</t>
                                </dd>

                                <dt class="col-sm-3">Desde</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="booking.start_datetime"/>
                                </dd>

                                <dt class="col-sm-3">Hasta</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="booking.end_datetime"/>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Acciones -->
                    <div class="d-flex justify-content-between">
                        <a href="/my/office-bookings" class="btn btn-outline-secondary">
                            &lt; Volver a mis reservas
                        </a>

                        <div>
                            <t t-if="booking.need_payment and not booking.paid">
                                <button class="btn btn-primary me-2" disabled="disabled">
                                    Pagar ahora (placeholder)
                                </button>
                            </t>

                            <t t-if="booking.state != 'cancelled' and not booking.paid">
                                <a t-att-href="'/my/office-bookings/%s/cancel' % booking.id"
                                   class="btn btn-outline-danger"
                                   t-att-data-confirm="'¿Seguro que quieres cancelar esta reserva?'">
                                    Cancelar reserva
                                </a>
                            </t>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>


</odoo>
