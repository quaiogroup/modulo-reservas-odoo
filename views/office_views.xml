<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_spoot_office_tree" model="ir.ui.view">
        <field name="name">spoot.office.tree</field>
        <field name="model">spoot.office</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="location"/>
                <field name="capacity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_spoot_office_form" model="ir.ui.view">
        <field name="name">spoot.office.form</field>
        <field name="model">spoot.office</field>
        <field name="arch" type="xml">
<form string="Oficina">
  <sheet>
    <group>
      <field name="name"/>
      <field name="image_1920" widget="image" class="oe_avatar"/>
    </group>

    <group>
      <field name="short_description"/>
    </group>

    <group>
      <field name="description"/>
    </group>

    <group>
      <field name="location"/>
      <field name="capacity"/>
    </group>

    <group string="Precios">
      <field name="price_morning"/>
      <field name="price_afternoon"/>
      <field name="price_full_day"/>
      <field name="currency_id"/>
    </group>

    <group>
      <field name="active"/>
    </group>

    <notebook>
      <page string="Galería">
        <field name="image_ids">
          <list editable="bottom">
            <field name="sequence"/>
            <field name="name"/>
            <field name="image_1920" widget="image" options="{'size': [128, 128]}"/>
          </list>
        </field>
      </page>
    </notebook>

  </sheet>
</form>
        </field>
    </record>

</odoo>
