<odoo>

<record id="view_coworking_plan_list" model="ir.ui.view">
    <field name="name">office.plan.list</field>
    <field name="model">office.plan</field>
    <field name="arch" type="xml">
        <list>
                <field name="name"/>
                <field name="days_included"/>
                <field name="price"/>
                <field name="validity_days"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_coworking_plan_form" model="ir.ui.view">
        <field name="name">office.plan.form</field>
        <field name="model">office.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="days_included"/>
                        <field name="price"/>
                        <field name="currency_id"/>
                        <field name="validity_days"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_coworking_plan" model="ir.actions.act_window">
        <field name="name">Planes de Coworking</field>
        <field name="res_model">office.plan</field>
<field name="view_mode">list,form</field>    
</record>

</odoo>