<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Action report ── -->
    <record id="action_report_booking_receipt" model="ir.actions.report">
        <field name="name">Comprobante de Reserva</field>
        <field name="model">office.booking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">office_booking.report_booking_receipt_template</field>
        <field name="report_file">office_booking.report_booking_receipt_template</field>
        <field name="binding_model_id" ref="model_office_booking"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ── QWeb template ── -->
    <template id="report_booking_receipt_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="booking">
                <t t-call="web.external_layout">
                    <div style="font-family: Arial, sans-serif; color: #1a1a1a; padding: 0 10px;">

                        <!-- Header -->
                        <div style="text-align: center; border-bottom: 3px solid #15803d; padding-bottom: 16px; margin-bottom: 24px;">
                            <h1 style="font-size: 24px; font-weight: bold; color: #15803d; margin: 0 0 4px 0;">
                                Comprobante de Reserva
                            </h1>
                            <p style="font-size: 13px; color: #6b7280; margin: 0;">Office Booking</p>
                        </div>

                        <!-- Reference number -->
                        <div style="text-align: center; margin-bottom: 28px;">
                            <p style="font-size: 12px; color: #6b7280; margin: 0 0 4px 0; text-transform: uppercase; letter-spacing: 1px;">
                                Número de referencia
                            </p>
                            <span style="font-family: 'Courier New', Courier, monospace; font-size: 22px; font-weight: bold; color: #15803d; background: #f0fdf4; padding: 6px 18px; border-radius: 6px; border: 1px solid #bbf7d0; display: inline-block;">
                                <t t-esc="booking.name or booking.id"/>
                            </span>
                        </div>

                        <!-- Detail table -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 28px; font-size: 13px;">
                            <thead>
                                <tr style="background: #15803d; color: #ffffff;">
                                    <th style="padding: 10px 12px; text-align: left; width: 35%;">Campo</th>
                                    <th style="padding: 10px 12px; text-align: left;">Detalle</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="background: #f9fafb;">
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Cliente</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-esc="booking.partner_id.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Email</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-esc="booking.partner_id.email or '-'"/>
                                    </td>
                                </tr>
                                <tr style="background: #f9fafb;">
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Oficina</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-esc="booking.office_id.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Fecha</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-esc="booking.date"/>
                                    </td>
                                </tr>
                                <tr style="background: #f9fafb;">
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Franja</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-if="booking.slot_type == 'morning'">Mañana (8:00–12:00)</t>
                                        <t t-elif="booking.slot_type == 'afternoon'">Tarde (14:00–18:00)</t>
                                        <t t-elif="booking.slot_type == 'full_day'">Día completo (8:00–18:00)</t>
                                        <t t-else=""><t t-esc="booking.slot_type"/></t>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; font-weight: bold; color: #374151;">Estado</td>
                                    <td style="padding: 9px 12px; border-bottom: 1px solid #e5e7eb; color: #1a1a1a;">
                                        <t t-esc="booking.state"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Payment section -->
                        <div style="background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px 20px; margin-bottom: 24px;">
                            <p style="font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px 0; font-weight: bold;">
                                Pago
                            </p>
                            <t t-if="booking.payment_mode == 'plan'">
                                <p style="font-size: 14px; color: #1a1a1a; margin: 0;">
                                    Plan de coworking —
                                    <strong>
                                        <t t-esc="'%.1f' % booking.plan_days_consumed"/> día(s) descontado(s)
                                    </strong>
                                </p>
                            </t>
                            <t t-else="">
                                <p style="font-size: 14px; color: #1a1a1a; margin: 0 0 4px 0;">
                                    Pago en línea (Bold)
                                </p>
                                <p style="font-size: 20px; font-weight: bold; color: #15803d; margin: 0;">
                                    $<t t-esc="'{:,.0f}'.format(booking.amount_total or 0)"/>
                                </p>
                            </t>
                        </div>

                        <!-- PAID stamp -->
                        <t t-if="booking.paid">
                            <div style="text-align: center; margin-bottom: 24px;">
                                <span style="display: inline-block; border: 3px solid #15803d; color: #15803d; font-size: 28px; font-weight: 900; letter-spacing: 4px; padding: 6px 24px; border-radius: 8px; text-transform: uppercase; opacity: 0.85;">
                                    PAGADO
                                </span>
                            </div>
                        </t>

                        <!-- Footer -->
                        <div style="border-top: 1px solid #e5e7eb; padding-top: 12px; text-align: center;">
                            <p style="font-size: 11px; color: #9ca3af; margin: 0;">
                                Generado el
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                — Office Booking
                            </p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
