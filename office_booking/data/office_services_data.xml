<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="spoot_service_wifi" model="office.service">
    <field name="name">WIFI de alta velocidad</field>
    <field name="icon">fa-wifi</field>
    <field name="description">Conexión estable para videollamadas</field>
    <field name="is_default">1</field>
    <field name="sequence">10</field>
  </record>

  <record id="spoot_service_hot_drinks" model="office.service">
    <field name="name">Bebidas calientes</field>
    <field name="icon">fa-mug-hot</field>
    <field name="description">Café / aromática / té</field>
    <field name="is_default">1</field>
    <field name="sequence">20</field>
  </record>

  <record id="spoot_service_video_beams" model="office.service">
    <field name="name">Video Beams</field>
    <field name="icon">fa-video</field>
    <field name="description">Proyector para reuniones</field>
    <field name="is_default">0</field>
    <field name="sequence">30</field>
  </record>

</odoo>
