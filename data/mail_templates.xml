    ${ '<div style="background:#fef3c7;border:1px solid #f59e0b;border-radius:6px;padding:14px 18px;margin-bottom:24px;font-size:14px;color:#92400e;">Los días de plan consumidos por esta reserva han sido devueltos a tu saldo de plan.</div>' if object.payment_mode == 'plan' and object.plan_days_consumed > 0 else '' }

