    <!-- ══════════════════════════════════════════════════════════════
         BOOKING TEMPLATES — ADMIN
         ══════════════════════════════════════════════════════════════ -->

    <!-- 6. Nueva reserva creada (admin) -->
    <record id="mail_template_booking_new_admin" model="mail.template">
        <field name="name">Reserva – Nueva reserva (admin)</field>
        <field name="model_id" ref="model_spoot_office_booking"/>
        <field name="subject">[Nueva reserva] ${object.partner_id.name} · ${object.office_id.name} · ${object.date}</field>
        <field name="email_from">${object.env.company.email or ''}</field>
        <field name="email_to">${object.env['ir.config_parameter'].sudo().get_param('spoot_office_booking.admin_email') or object.env.company.email or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html">
<![CDATA[
<div style="font-family:Arial,Helvetica,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
  <div style="background:#1e293b;padding:20px 28px;">
    <h2 style="color:#ffffff;margin:0;font-size:18px;">Nueva reserva recibida</h2>
  </div>
  <div style="padding:28px;">
    <table style="width:100%;border-collapse:collapse;font-size:14px;">
      <tr style="background:#f8fafc;">
        <td style="padding:9px 14px;font-weight:bold;color:#374151;width:38%;border-bottom:1px solid #e5e7eb;">Referencia</td>
        <td style="padding:9px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.name}</td>
      </tr>
      <tr>
        <td style="padding:9px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Cliente</td>
        <td style="padding:9px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.partner_id.name} (${object.partner_id.email or 'sin email'})</td>
      </tr>
