<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">

    <!-- ══════════════════════════════════════════════════════════════
         BOOKING TEMPLATES — CUSTOMER
         ══════════════════════════════════════════════════════════════ -->

    <!-- 1. Reserva pendiente de pago (Bold) -->
    <record id="mail_template_booking_pending_payment" model="mail.template">
        <field name="name">Reserva – Pendiente de pago (cliente)</field>
        <field name="model_id" ref="model_spoot_office_booking"/>
        <field name="subject">Tu reserva está pendiente de pago – ${object.office_id.name}</field>
        <field name="email_from">${object.env.company.email or ''}</field>
        <field name="email_to">${object.partner_id.email or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html">
<![CDATA[
<div style="font-family:Arial,Helvetica,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
  <div style="background:#1e293b;padding:28px 32px;text-align:center;">
    <h1 style="color:#ffffff;margin:0;font-size:22px;letter-spacing:0.5px;">SPPOT Office Booking</h1>
  </div>
  <div style="padding:32px;">
    <p style="margin:0 0 16px;font-size:16px;color:#111827;">Hola <strong>${object.partner_id.name}</strong>,</p>
    <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
      Hemos creado tu reserva de oficina. Para confirmarla, debes completar el pago a través del botón que encontrarás en el portal.
    </p>

    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:14px;">
      <tr style="background:#f8fafc;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;width:40%;border-bottom:1px solid #e5e7eb;">Referencia</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.name}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Oficina</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.office_id.name}${ (' – ' + object.office_id.location) if object.office_id.location else '' }</td>
      </tr>
      <tr style="background:#f8fafc;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Fecha</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.date}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Franja horaria</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${{'morning':'Mañana (8:00 – 12:00)','afternoon':'Tarde (14:00 – 18:00)','full_day':'Día completo (8:00 – 18:00)'}.get(object.slot_type, object.slot_type)}</td>
      </tr>
      <tr style="background:#f8fafc;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;">Valor</td>
        <td style="padding:10px 14px;color:#111827;">${'{:,.0f}'.format(object.amount_total)} ${object.currency_id.name}</td>
      </tr>
    </table>

    <div style="text-align:center;margin:28px 0;">
      <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/office-bookings/${object.id}"
         style="background:#2563eb;color:#ffffff;text-decoration:none;padding:13px 28px;border-radius:6px;font-size:15px;font-weight:bold;display:inline-block;">
        Completar pago →
      </a>
    </div>

    <p style="font-size:13px;color:#6b7280;line-height:1.5;">
      Tu reserva quedará confirmada automáticamente una vez que el pago sea procesado exitosamente.
      Si tienes dudas, responde a este correo o visita <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/coworking" style="color:#2563eb;">tu portal de coworking</a>.
    </p>
  </div>
  <div style="background:#f1f5f9;padding:16px 32px;text-align:center;font-size:12px;color:#6b7280;">
    SPPOT SAS · <a href="https://sppot.co" style="color:#2563eb;">sppot.co</a>
  </div>
</div>
]]>
        </field>
    </record>

    <!-- 2. Reserva confirmada tras pago Bold -->
    <record id="mail_template_booking_confirmed_bold" model="mail.template">
        <field name="name">Reserva – Confirmada (pago Bold, cliente)</field>
        <field name="model_id" ref="model_spoot_office_booking"/>
        <field name="subject">✓ Reserva confirmada – ${object.office_id.name} · ${object.date}</field>
        <field name="email_from">${object.env.company.email or ''}</field>
        <field name="email_to">${object.partner_id.email or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html">
<![CDATA[
<div style="font-family:Arial,Helvetica,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
  <div style="background:#15803d;padding:28px 32px;text-align:center;">
    <h1 style="color:#ffffff;margin:0;font-size:22px;">¡Reserva confirmada!</h1>
  </div>
  <div style="padding:32px;">
    <p style="margin:0 0 16px;font-size:16px;color:#111827;">Hola <strong>${object.partner_id.name}</strong>,</p>
    <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
      Tu pago fue procesado exitosamente. Tu reserva de oficina está <strong>confirmada</strong>.
    </p>

    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:14px;">
      <tr style="background:#f0fdf4;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;width:40%;border-bottom:1px solid #e5e7eb;">Referencia</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.name}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Oficina</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.office_id.name}${ (' – ' + object.office_id.location) if object.office_id.location else '' }</td>
      </tr>
      <tr style="background:#f0fdf4;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Fecha</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.date}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Franja horaria</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${{'morning':'Mañana (8:00 – 12:00)','afternoon':'Tarde (14:00 – 18:00)','full_day':'Día completo (8:00 – 18:00)'}.get(object.slot_type, object.slot_type)}</td>
      </tr>
      <tr style="background:#f0fdf4;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Forma de pago</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">Pago en línea (Bold)</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;">Valor pagado</td>
        <td style="padding:10px 14px;color:#111827;">${'{:,.0f}'.format(object.amount_total)} ${object.currency_id.name}</td>
      </tr>
    </table>

    <div style="text-align:center;margin:28px 0;">
      <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/office-bookings/${object.id}"
         style="background:#15803d;color:#ffffff;text-decoration:none;padding:13px 28px;border-radius:6px;font-size:15px;font-weight:bold;display:inline-block;">
        Ver reserva →
      </a>
    </div>

    <p style="font-size:13px;color:#6b7280;line-height:1.5;">
      Recuerda presentarte puntualmente el día de tu reserva.
      Si necesitas cancelarla, puedes hacerlo desde <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/office-bookings" style="color:#2563eb;">tu portal</a>.
    </p>
  </div>
  <div style="background:#f1f5f9;padding:16px 32px;text-align:center;font-size:12px;color:#6b7280;">
    SPPOT SAS · <a href="https://sppot.co" style="color:#2563eb;">sppot.co</a>
  </div>
</div>
]]>
        </field>
    </record>

    <!-- 3. Reserva confirmada con plan de coworking -->
    <record id="mail_template_booking_confirmed_plan" model="mail.template">
        <field name="name">Reserva – Confirmada (plan coworking, cliente)</field>
        <field name="model_id" ref="model_spoot_office_booking"/>
        <field name="subject">✓ Reserva confirmada con tu plan – ${object.office_id.name} · ${object.date}</field>
        <field name="email_from">${object.env.company.email or ''}</field>
        <field name="email_to">${object.partner_id.email or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html">
<![CDATA[
<div style="font-family:Arial,Helvetica,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
  <div style="background:#0f766e;padding:28px 32px;text-align:center;">
    <h1 style="color:#ffffff;margin:0;font-size:22px;">¡Reserva confirmada con tu plan!</h1>
  </div>
  <div style="padding:32px;">
    <p style="margin:0 0 16px;font-size:16px;color:#111827;">Hola <strong>${object.partner_id.name}</strong>,</p>
    <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
      Tu reserva fue confirmada usando el saldo de tu plan de coworking. No se requiere ningún pago adicional.
    </p>

    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:14px;">
      <tr style="background:#f0fdfa;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;width:40%;border-bottom:1px solid #e5e7eb;">Referencia</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.name}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Oficina</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.office_id.name}${ (' – ' + object.office_id.location) if object.office_id.location else '' }</td>
      </tr>
      <tr style="background:#f0fdfa;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Fecha</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.date}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Franja horaria</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${{'morning':'Mañana (8:00 – 12:00)','afternoon':'Tarde (14:00 – 18:00)','full_day':'Día completo (8:00 – 18:00)'}.get(object.slot_type, object.slot_type)}</td>
      </tr>
      <tr style="background:#f0fdfa;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Forma de pago</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">Plan de coworking${ (' – ' + object.subscription_id.plan_id.name) if object.subscription_id else '' }</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;">Días descontados del plan</td>
        <td style="padding:10px 14px;color:#111827;">${object.plan_days_consumed} día(s)</td>
      </tr>
    </table>

    <div style="text-align:center;margin:28px 0;">
      <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/coworking"
         style="background:#0f766e;color:#ffffff;text-decoration:none;padding:13px 28px;border-radius:6px;font-size:15px;font-weight:bold;display:inline-block;">
        Ver mi plan →
      </a>
    </div>

    <p style="font-size:13px;color:#6b7280;line-height:1.5;">
      Si necesitas cancelar la reserva, los días descontados serán restituidos a tu plan automáticamente.
    </p>
  </div>
  <div style="background:#f1f5f9;padding:16px 32px;text-align:center;font-size:12px;color:#6b7280;">
    SPPOT SAS · <a href="https://sppot.co" style="color:#2563eb;">sppot.co</a>
  </div>
</div>
]]>
        </field>
    </record>

    <!-- 4. Recordatorio 24h antes de la reserva -->
    <record id="mail_template_booking_reminder" model="mail.template">
        <field name="name">Reserva – Recordatorio (cliente)</field>
        <field name="model_id" ref="model_spoot_office_booking"/>
        <field name="subject">Recordatorio: tu reserva en ${object.office_id.name} es mañana</field>
        <field name="email_from">${object.env.company.email or ''}</field>
        <field name="email_to">${object.partner_id.email or ''}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html">
<![CDATA[
<div style="font-family:Arial,Helvetica,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
  <div style="background:#7c3aed;padding:28px 32px;text-align:center;">
    <h1 style="color:#ffffff;margin:0;font-size:22px;">📅 Recordatorio de reserva</h1>
  </div>
  <div style="padding:32px;">
    <p style="margin:0 0 16px;font-size:16px;color:#111827;">Hola <strong>${object.partner_id.name}</strong>,</p>
    <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
      Te recordamos que mañana tienes una reserva de oficina confirmada. ¡No olvides llegar puntualmente!
    </p>

    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:14px;">
      <tr style="background:#faf5ff;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;width:40%;border-bottom:1px solid #e5e7eb;">Oficina</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.office_id.name}${ (' – ' + object.office_id.location) if object.office_id.location else '' }</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Fecha</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${object.date}</td>
      </tr>
      <tr style="background:#faf5ff;">
        <td style="padding:10px 14px;font-weight:bold;color:#374151;border-bottom:1px solid #e5e7eb;">Franja horaria</td>
        <td style="padding:10px 14px;color:#111827;border-bottom:1px solid #e5e7eb;">${{'morning':'Mañana (8:00 – 12:00)','afternoon':'Tarde (14:00 – 18:00)','full_day':'Día completo (8:00 – 18:00)'}.get(object.slot_type, object.slot_type)}</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;font-weight:bold;color:#374151;">Referencia</td>
        <td style="padding:10px 14px;color:#111827;">${object.name}</td>
      </tr>
    </table>

    <div style="text-align:center;margin:28px 0;">
      <a href="${object.env['ir.config_parameter'].sudo().get_param('web.base.url')}/my/office-bookings/${object.id}"
         style="background:#7c3aed;color:#ffffff;text-decoration:none;padding:13px 28px;border-radius:6px;font-size:15px;font-weight:bold;display:inline-block;">
        Ver detalle →
      </a>
    </div>

    <p style="font-size:13px;color:#6b7280;line-height:1.5;">
      Si necesitas cancelar, puedes hacerlo desde tu portal antes de la fecha de la reserva.
    </p>
  </div>
  <div style="background:#f1f5f9;padding:16px 32px;text-align:center;font-size:12px;color:#6b7280;">
    SPPOT SAS · <a href="https://sppot.co" style="color:#2563eb;">sppot.co</a>
  </div>
</div>
]]>
        </field>
    </record>

